{
  "version": 2,
  "name": "jamb-cbt-platform",
  "buildCommand": "echo 'No build needed - serving static files'",
  "outputDirectory": ".",
  "installCommand": "echo 'No install needed'",
  "framework": null,
  "routes": [
    {
      "src": "/index-new.html",
      "dest": "/index-new.html"
    },
    {
      "src": "/config.js",
      "dest": "/config.js"
    },
    {
      "src": "/database.js",
      "dest": "/database.js"
    },
    {
      "src": "/auth.js",
      "dest": "/auth.js"
    },
    {
      "src": "/exam-engine.js",
      "dest": "/exam-engine.js"
    },
    {
      "src": "/ui-components.js",
      "dest": "/ui-components.js"
    },
    {
      "src": "/app-new.js",
      "dest": "/app-new.js"
    },
    {
      "src": "/styles-new.css",
      "dest": "/styles-new.css"
    },
    {
      "src": "/",
      "dest": "/index-new.html"
    },
    {
      "src": "/(.*)",
      "dest": "/index-new.html"
    }
  ],
  "git": {
    "deploymentEnabled": true
  }
}
