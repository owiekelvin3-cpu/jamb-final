{
  "version": 2,
  "name": "jamb-learning",
  "buildCommand": "echo 'No build needed - serving static files'",
  "outputDirectory": ".",
  "installCommand": "echo 'No install needed'",
  "framework": null,
  "routes": [
    {
      "src": "/index.html",
      "dest": "/index.html"
    },
    {
      "src": "/app.js",
      "dest": "/app.js"
    },
    {
      "src": "/curriculum.js",
      "dest": "/curriculum.js"
    },
    {
      "src": "/supabase-client.js",
      "dest": "/supabase-client.js"
    },
    {
      "src": "/styles.css",
      "dest": "/styles.css"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ],
  "git": {
    "deploymentEnabled": true
  }
}
